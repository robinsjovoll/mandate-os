{
  "name": "mandate-os",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "nx": "nx",
    "build": "pnpm exec nx run-many --target=build --projects=mandate-os-homepage,@mandate-os/sdk,@mandate-os/mcp,@mandate-os/openclaw --parallel=1",
    "test": "pnpm exec nx run-many --target=test --projects=mandate-os-homepage,@mandate-os/sdk,@mandate-os/mcp,@mandate-os/openclaw --parallel=1",
    "lint": "pnpm exec nx run mandate-os-homepage:lint",
    "format": "pnpm exec prettier --write --ignore-unknown .",
    "format:check": "pnpm exec prettier --check --ignore-unknown .",
    "mandate-os:homepage:start": "pnpm exec nx run mandate-os-homepage:serve",
    "mandate-os:homepage:build": "pnpm exec nx run mandate-os-homepage:build",
    "mandate-os:homepage:test": "pnpm exec nx run mandate-os-homepage:test",
    "mandate-os:homepage:deploy": "pnpm exec nx run mandate-os-homepage:deploy",
    "mandate-os:homepage:infrastructure": "pnpm exec nx run mandate-os-homepage:infrastructure",
    "mandate-os:sdk:build": "pnpm --dir packages/mandate-os-sdk run build",
    "mandate-os:sdk:test": "pnpm --dir packages/mandate-os-sdk run test",
    "mandate-os:mcp:build": "pnpm --dir packages/mandate-os-mcp run build",
    "mandate-os:mcp:test": "pnpm --dir packages/mandate-os-mcp run test",
    "mandate-os:mcp:start": "pnpm --dir packages/mandate-os-mcp run start",
    "mandate-os:openclaw:build": "pnpm --dir packages/mandate-os-openclaw run build",
    "mandate-os:openclaw:test": "pnpm --dir packages/mandate-os-openclaw run test",
    "mandate-os:cursor:install": "pnpm mandate-os:mcp:build && pnpm --dir packages/mandate-os-mcp run cursor:install",
    "mandate-os:cursor:status": "pnpm mandate-os:mcp:build && pnpm --dir packages/mandate-os-mcp run cursor:status",
    "mandate-os:claude:install": "pnpm mandate-os:mcp:build && pnpm --dir packages/mandate-os-mcp run claude:install",
    "mandate-os:claude:status": "pnpm mandate-os:mcp:build && pnpm --dir packages/mandate-os-mcp run claude:status",
    "mandate-os:openclaw:install": "MANDATE_OS_OPENCLAW_WORKSPACE_PATH=$PWD pnpm --dir packages/mandate-os-openclaw run build && MANDATE_OS_OPENCLAW_WORKSPACE_PATH=$PWD pnpm --dir packages/mandate-os-openclaw run openclaw:install",
    "mandate-os:openclaw:repair": "MANDATE_OS_OPENCLAW_WORKSPACE_PATH=$PWD pnpm --dir packages/mandate-os-openclaw run build && MANDATE_OS_OPENCLAW_WORKSPACE_PATH=$PWD pnpm --dir packages/mandate-os-openclaw run openclaw:repair",
    "mandate-os:openclaw:status": "MANDATE_OS_OPENCLAW_WORKSPACE_PATH=$PWD pnpm --dir packages/mandate-os-openclaw run build && MANDATE_OS_OPENCLAW_WORKSPACE_PATH=$PWD pnpm --dir packages/mandate-os-openclaw run openclaw:status",
    "mandate-os:packages:release:dry-run": "node scripts/releases/publish-mandate-os-packages.mjs --dry-run --uncommitted",
    "mandate-os:packages:publish": "node scripts/releases/publish-mandate-os-packages.mjs --publish"
  },
  "dependencies": {
    "@angular/common": "~21.2.6",
    "@angular/compiler": "~21.2.6",
    "@angular/core": "~21.2.6",
    "@angular/platform-browser": "~21.2.6",
    "@angular/platform-browser-dynamic": "~21.2.6",
    "rxjs": "~7.8.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~21.2.5",
    "@angular/build": "~21.2.5",
    "@angular/cli": "~21.2.5",
    "@angular/compiler-cli": "~21.2.6",
    "@eslint/js": "^10.0.1",
    "@nx/angular": "22.6.3",
    "@nx/eslint": "22.6.3",
    "@nx/eslint-plugin": "22.6.3",
    "@nx/jest": "22.6.3",
    "@nx/js": "22.6.3",
    "@nx/vitest": "22.6.3",
    "@nx/web": "22.6.3",
    "@nx/workspace": "22.6.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "angular-eslint": "^21.3.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-preset-angular": "~16.1.2",
    "nx": "22.6.3",
    "prettier": "~3.8.1",
    "ts-jest": "^29.1.0",
    "ts-node": "10.9.2",
    "tslib": "^2.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^8.0.3",
    "vitest": "^4.0.8"
  }
}
